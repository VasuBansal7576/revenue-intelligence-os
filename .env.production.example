CDI_TENANT_ID=tenant_123
CDI_AUTH_TOKEN=replace-me
CDI_API_BASE_URL=https://api.example.com

HYDRA_DB_API_KEY=replace-me
HYDRA_DB_BASE_URL=https://api.hydradb.com

CDI_LLM_PROVIDER=codex
CDI_LLM_MODEL=gpt-5.3-codex
CODEX_AUTH_FILE=/etc/cdi/codex-auth.json

CDI_TRANSCRIPTION_COMMAND=uv run '/opt/revenue-intelligence-os/scripts/transcribe_faster_whisper.py' {audio_path}

CDI_JOB_STORE_PATH=/var/lib/cdi/ingestion-jobs.jsonl
PROVIDER_HTTP_TIMEOUT_SECONDS=30

CDI_CRM_PROVIDER=manual
CRM_CLIENT_ID=replace-me
CRM_CLIENT_SECRET=replace-me
CRM_WEBHOOK_SECRET=replace-me

CDI_SERVICE_TOKEN_HMAC_SECRET=
CDI_SERVICE_TOKEN_ISSUER=cdi
CDI_SERVICE_TOKEN_AUDIENCE=providers

CDI_API_HOST=127.0.0.1
CDI_API_PORT=8010
CDI_WEB_HOST=127.0.0.1
CDI_WEB_PORT=3000
CDI_FORWARDED_ALLOW_IPS=127.0.0.1
